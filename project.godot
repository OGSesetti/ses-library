; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SES-library"
run/main_scene="res://ses/menu manager/scenes/independent menus/testmenu.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")

[autoload]

Enums="*res://ses/core components/enums.gd"
GameEnums="*res://game/data/game_enums.gd"
FilePaths="*res://ses/core components/ses_config/file_paths.gd"
SesConfig="*res://ses/core components/ses_config/ses_config.tscn"
Ses="*res://ses/core components/sestem.gd"
SaveManager="*res://ses/save manager/save_manager.gd"
SesApi="res://ses/core components/ses_middleware.gd"
SettingsManager="*res://ses/settings manager/scripts/settings_manager.gd"
SignalManager="*res://ses/core components/signal_manager.gd"
MenuManager="*res://ses/menu manager/scenes/menu_manager.tscn"
LevelIndex="*res://game/scripts/level_index.gd"
Main="*res://game/scenes/main.tscn"
GameObject="*res://game/data/game_object_reference.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[gui]

fonts/dynamic_fonts/use_oversampling=false
theme/default_font_hinting=2
theme/default_font_subpixel_positioning=0
theme/lcd_subpixel_layout=0

